<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.MainPage">

    <VerticalStackLayout Padding="10">
        <Button x:Name="CounterBtn" Text="Teste" />

        <!-- FILTRO -->
        <Picker Title="Filtrar por Categoria"
                x:Name="filtroCategoria"
                SelectedIndexChanged="OnCategoriaSelecionada">

            <Picker.Items>
                <x:String>Todos</x:String>
                <x:String>Alimentos</x:String>
                <x:String>Higiene</x:String>
                <x:String>Limpeza</x:String>
            </Picker.Items>
        </Picker>

        <!-- LISTA -->
        <ListView x:Name="listaProdutos">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <TextCell Text="{Binding Descricao}" 
                              Detail="{Binding Categoria}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </VerticalStackLayout>

</ContentPage>