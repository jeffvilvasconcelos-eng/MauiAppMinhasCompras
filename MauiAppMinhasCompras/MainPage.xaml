<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.MainPage">

    <VerticalStackLayout Padding="10">
        <Button x:Name="CounterBtn" Text="Teste" />


        <!-- FILTRO -->
        <Picker Title="Filtrar por Categoria"
                x:Name="filtroCategoria">


            <Picker.Items>
                <x:String>Alimentos</x:String>
                <x:String>Higiene</x:String>
                <x:String>Limpeza</x:String>
                <x:String>Bazar</x:String>
            </Picker.Items>
        </Picker>

        <Entry x:Name="txtFiltroCategoria"
               Placeholder="Digite a Categoria" />



        <CollectionView x:Name="listaProdutos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Padding="10" Margin="5">
                        <VerticalStackLayout>

                            <!-- DESCRIÇÃO -->
                            <Label Text="{Binding Descricao}" 
                           FontAttributes="Bold"/>

                            <!-- CATEGORIA -->
                            <Label Text="{Binding Categoria}" />

                            <!-- PREÇO -->
                            <Label Text="{Binding Preco, StringFormat='Preço: R$ {0:F2}'}" />

                            <!-- QUANTIDADE -->
                            <Label Text="{Binding Quantidade, StringFormat='Qtd: {0}'}" />

                            <!-- TOTAL -->
                            <Label Text="{Binding Total, StringFormat='Total: R$ {0:F2}'}" />

                            <!-- ✅ DATA (CORREÇÃO PRINCIPAL) -->
                            <Label Text="{Binding DataCadastro, StringFormat='Data: {0:dd/MM/yyyy}'}"
                           FontSize="12"
                           TextColor="Gray"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>