<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />       
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label">
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout>
        <SearchBar x:Name="txt_search"
                   Margin="10, 0, 10, 0"
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged"/>

        <VerticalStackLayout Padding="10">

            <!-- FILTRO -->
            <Picker Title="Filtrar por Categoria"
            x:Name="filtroCategoria"
            SelectedIndexChanged="OnFiltroCategoriaChanged">

                <Picker.Items>
                    <x:String>Todos</x:String>
                    <x:String>Alimentos</x:String>
                    <x:String>Higiene</x:String>
                    <x:String>Limpeza</x:String>
                    <x:String>Bazar</x:String>
                </Picker.Items>
            </Picker>

            <!-- BOTÃO RELATÓRIO -->
            <Button Text="Ver Relatório"
            Clicked="OnAbrirRelatorio"
            BackgroundColor="orange"
            TextColor="White"/>

            <!-- LISTA -->
            <CollectionView x:Name="listaProdutos">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="Gray" Padding="10" Margin="5">
                            <VerticalStackLayout>

                                <Label Text="{Binding Descricao}" FontAttributes="Bold"/>
                                <Label Text="{Binding Categoria}" />

                                <Label Text="{Binding Preco, StringFormat='Preço: R$ {0:F2}'}"/>
                                <Label Text="{Binding Quantidade, StringFormat='Qtd: {0}'}"/>
                                <Label Text="{Binding Total, StringFormat='Total: R$ {0:F2}'}"/>

                                <!-- DATA -->
                                <Label Text="{Binding DataCadastro, StringFormat='Data: {0:dd/MM/yyyy}'}"
                               FontSize="12"
                               TextColor="Gray"/>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <Frame Padding="0" Margin="10" VerticalOptions="FillAndExpand">
            <ListView x:Name="lst_produtos"
                      IsPullToRefreshEnabled="True"
                      Refreshing="lst_produtos_Refreshing"
                      ItemSelected="lst_produtos_ItemSelected">
                <ListView.Header>
                    <Grid ColumnDefinitions="30, 200, 80, 50, 90, 100, 80"
                          BackgroundColor="orange">
                        <Label Grid.Column="0" Text="ID" Padding="5" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="Preço" FontAttributes="Bold" />
                        <Label Grid.Column="3" Text="Qnt" FontAttributes="Bold" />
                        <Label Grid.Column="4" Text="Total" FontAttributes="Bold" />
                        <Label Grid.Column="5" Text="Categoria" FontAttributes="Bold" />
                        <Label Grid.Column="6" Text="Data" FontAttributes="Bold" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <ViewCell.ContextActions>
                                <MenuItem Text="Remover" Clicked="MenuItem_Clicked" />
                            </ViewCell.ContextActions>
                            <Grid ColumnDefinitions="30, 200, 80, 50, 90, 100, 80">
                                <Label Grid.Column="0" Text="{Binding Id}" Padding="5" />
                                <Label Grid.Column="1" Text="{Binding Descricao}" />
                                <Label Grid.Column="2" Text="{Binding Preco, StringFormat='{}{0:c}'}" />
                                <Label Grid.Column="3" Text="{Binding Quantidade}" />
                                <Label Grid.Column="4" Text="{Binding Total, StringFormat='{}{0:c}'}" />
                                <Label Grid.Column="5" Text="{Binding Categoria}" />
                                <Label Grid.Column="6" Text="{Binding Data}" />
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Frame>
    </StackLayout>
</ContentPage>