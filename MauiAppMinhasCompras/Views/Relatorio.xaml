<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio"
             Title="Relatorio">
    <VerticalStackLayout Padding="10">
        <Label 
            Text="Relatório por Categoria"
            FontSize="20" />
        <Button Text="Carregar Relatório"
                Clicked="Button_Clicked" />

        <CollectionView x:Name="listaCategoria">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" Padding="10" Margin="5">
                        <HorizontalStackLayout>


                            <Label Text="{Binding Categoria}" FontAttributes="Bold" />

                            <Label Text="{Binding Total, StringFormat='R$ {0:F2}'}" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>