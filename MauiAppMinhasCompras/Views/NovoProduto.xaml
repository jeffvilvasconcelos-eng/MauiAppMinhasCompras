<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto"> 
    
 <!-- botão salvar -->
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="10">

            <!--categoria-->
            <Picker Title ="Selecione uma Categoria:" x:Name="pickerCategoria">

                <Picker.Items>
                    <x:String>Alimentos</x:String>
                    <x:String>Higiene</x:String>
                    <x:String>Limpeza</x:String>
                    <x:String>Bazar</x:String>
                </Picker.Items>
            </Picker>

            <!-- descrição-->
            <Label Text="Descrição do Produto:" />
            <Entry
            x:Name="txt_descricao" />
            <!-- quantidade -->
            <Label Text="Quantidade:" />
            <Entry
            x:Name="txt_quantidade" Keyboard="Numeric" />
            <!-- preço-->
            <Label Text="Preço Unitário:" />
            <Entry
            x:Name="txt_preco" Keyboard="Numeric" />
            <!-- data-->
            <Label Text="Data da Compra" /> 
            <DatePicker x:Name="dtData" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>